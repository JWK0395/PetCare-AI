# ============================================================
# PetCare AI Agent 서비스 환경 변수
#
# 사용법: 이 파일을 ai/.env 로 복사한 뒤 값을 채운다.
#   cp .env.example .env
#
# 읽는 곳이 두 군데다.
#   1) ai/app/config.py  — pydantic-settings 가 ai/.env 를 Settings 필드로 로드
#   2) petcare_ai        — os.environ 을 직접 읽는다 (API 키·모델·index 경로)
# 2)를 위해 config.load_provider_env() 가 ai/.env 값을 os.environ 으로 올린다.
# **OS 환경변수가 이미 있으면 그쪽이 우선한다**(컨테이너/systemd 주입이 파일보다 강함).
#
# 아래 값은 전부 placeholder 다. 실제 키를 이 파일에 적지 않는다.
# 실제 키는 ai/.env 에만 두며 커밋하지 않는다(루트 .gitignore 가 **/.env 차단).
# ============================================================

# --- LLM (필수) ---------------------------------------------
# 키가 없으면 서비스는 기동되지만 AI 기능이 "정리하지 못했습니다" 로 응답한다.
# 아래는 placeholder 다. 실제 키로 바꾼 뒤 ai/.env 에만 두고 절대 커밋하지 않는다.
OPENAI_API_KEY=<OPENAI_API_KEY>
LLM_PROVIDER=openai
LLM_MODEL=gpt-5.4-mini
# (호환) 초기 스텁이 안내하던 provider 중립 이름. 값을 여기에 넣어도 되며,
# OPENAI_API_KEY 가 비어 있을 때 자동으로 승격된다(anthropic 이면 ANTHROPIC_API_KEY).
# 둘 다 채우면 OPENAI_API_KEY 가 우선한다.
#LLM_API_KEY=

# --- RAG (수의학 근거 검색) ----------------------------------
# AWS 프리티어(RAM 1GB)에서는 반드시 openai 여야 한다.
# huggingface 는 torch + bge-m3 를 올려 인스턴스를 죽인다(requirements.txt 참고).
EMBEDDING_BACKEND=openai
# 미리 만들어 배포한 FAISS index 폴더(안에 faiss_dog / faiss_cat 이 있어야 한다).
# 절대경로 권장 — 상대경로는 실행 위치(CWD)에 따라 다른 폴더를 가리킨다.
PETCARE_INDEX_DIR=/opt/petcare/faiss_index

# 근거가 부족할 때만 호출하는 수의학 웹 검색(선택).
# 비워 두면 웹 fallback 없이 내부 RAG 근거만 사용한다.
TAVILY_API_KEY=

# --- 메인 서버 연결 -----------------------------------------
# 메인 서버의 AGENT_API_KEY 와 같은 값을 넣으면 Authorization: Bearer 검증이 켜진다.
# 비워 두면 검증 없이 통과한다 — 로컬 개발에서만 비워 둘 것.
AGENT_API_KEY=
#
# 참고: 이 서비스는 메인 서버를 **호출하지 않는다**. 요약 저장·이메일 초안은
# 서버가 자기 DB 로 처리한다. 그래서 서버 주소 설정이 없다(단방향: 서버 → AI).

# --- LangSmith 추적 (선택) ----------------------------------
# 켜면 대화 trace 가 LangSmith 로 전송된다. 개인정보는 metadata 에 넣지 않는다
# (petcare_ai/graph/builder.py 의 build_trace_metadata 참고).
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=petcare-ai
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# --- petcare_ai 경로 (선택) ---------------------------------
# petcare_ai 는 ai/ 안에 함께 있어 보통 지정할 필요가 없다.
# 다른 위치에서 실행할 때만 petcare_ai 상위 폴더 경로를 지정한다.
#PETCARE_AI_PATH=/opt/petcare/PetCare-AI/ai
