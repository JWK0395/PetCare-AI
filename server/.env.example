# ============================================================
# PetCare AI — 메인 서버 환경 변수
# 사용법: 이 파일을 server/.env 로 복사한 뒤 값 수정 (모두 선택 — 기본값으로 동작)
#   cp .env.example .env
# ============================================================

# --- AI Agent 연결 -----------------------------------
AGENT_API_KEY=

# --- CORS  --------------------------------------------
CORS_ORIGINS=*

# --- 업로드 -------------------------------------------
MAX_UPLOAD_MB=10
ALLOWED_UPLOAD_EXTENSIONS=.pdf,.png,.jpg,.jpeg

# --- 인증 시도 제한 ------------------------------------
AUTH_RATE_LIMIT_ATTEMPTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=300