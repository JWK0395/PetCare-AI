# ============================================================
# PetCare AI — 메인 서버 환경 변수
# 사용법: 이 파일을 server/.env 로 복사한 뒤 값 수정 (모두 선택 — 기본값으로 동작)
#   cp .env.example .env
# ============================================================

# --- Database (선택) ---------------------------------------
# 기본값: server/data/petcare.db (절대경로, 자동 생성)
# 주의: 상대경로(sqlite:///./...)는 실행 위치(CWD)에 따라 다른 파일을 만들므로 권장하지 않음
#DATABASE_URL=sqlite:///C:/path/to/petcare.db

# --- AI Agent 연결 (선택) -----------------------------------
# 허용값: mock | http
#   mock : 내장 규칙 기반 응답 (외부 Agent 불필요, 기본값)
#   http : ai/ 서비스로 전달 (계약: ai/README.md)
AGENT_MODE=mock
AGENT_BASE_URL=http://127.0.0.1:8100
AGENT_TIMEOUT_SECONDS=60
# 설정 시 Agent 서비스에 Authorization: Bearer <key> 로 전달됨
AGENT_API_KEY=

# --- CORS (선택) --------------------------------------------
# 쉼표로 구분한 허용 origin 목록. RN 앱만 쓰는 로컬 개발은 * 로 충분.
# 웹 클라이언트 연동 시 정확한 origin 나열: http://localhost:3000,https://example.com
CORS_ORIGINS=*

# --- 업로드 (선택) -------------------------------------------
# 진단서 업로드 최대 크기(MB, 1~100)와 허용 확장자
MAX_UPLOAD_MB=10
ALLOWED_UPLOAD_EXTENSIONS=.pdf,.png,.jpg,.jpeg

# --- 인증 시도 제한 (선택) ------------------------------------
# 로그인/회원가입: 같은 IP+이메일 기준 창(window) 내 최대 시도 횟수
AUTH_RATE_LIMIT_ATTEMPTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=300

# --- 데모 데이터 (선택) ---------------------------------------
# DB 가 비어 있을 때 데모 계정 + 콩이 + 30일 기록 + 진단서를 시드한다.
# 병원은 시드하지 않는다 — 응급 안내에 쓸 병원은 AI 가 실시간 검색으로 찾는다.
SEED_DEMO_DATA=true
DEMO_USER_EMAIL=demo@petcare.ai
DEMO_USER_PASSWORD=demo1234
