OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=petcare-ai-assessment
LANGSMITH_RUN_PREFIX=assessment_graph
PETCARE_API_BASE_URL=http://localhost:8000
PETCARE_ENV=local

# Cornell RAG local vector store
# OPENAI_API_KEY is also used for text-embedding-3-small embeddings
PETCARE_RAG_DB_PATH=rag_data/chroma
PETCARE_RAG_COLLECTION=cornell_pet_health_text_embedding_3_small_1536
